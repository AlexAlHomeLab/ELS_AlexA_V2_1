{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Wokwi GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/ELS_AlexA_V2.1.ino.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/ignore/gdb/avr-gcc-15.2.0-x64-windows/bin/avr-gdb.exe",  // Укажите путь к GDB для вашей архитектуры
            "miDebuggerServerAddress": "localhost:3333",
            "preLaunchTask": "Arduino: Compile Mega (Wokwi)"
        }
    ]
}